{
  "name": "ASP.NET MVC DevContainer",
  "image": "mcr.microsoft.com/dotnet/sdk:7.0",
  "features": {
    "git": "latest"
  },
  "postCreateCommand": "dotnet restore",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.vscode-dotnet-runtime"
      ]
    }
  },
  "forwardPorts": [5000, 5001],
  "remoteUser": "vscode"
}
