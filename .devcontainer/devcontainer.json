{
  "name": "ASP.NET MVC Codespace",
  "image": "mcr.microsoft.com/vscode/devcontainers/dotnet:0-7.0",
  "features": {
    "git": "latest"
  },
  "forwardPorts": [5000, 5001],
  "postCreateCommand": "dotnet restore",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.vscode-dotnet-runtime"
      ]
    }
  },
  "remoteUser": "root"
}
